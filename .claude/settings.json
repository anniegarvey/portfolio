{
  "permissions": {
    "allow": [
      "Bash(pnpm tsc --noEmit *)",
      "Bash(pnpm exec tsc --noEmit *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm test *)",
      "Bash(pnpm vitest run *)",
      "Bash(pnpm exec vitest run *)",
      "Bash(pnpm i *)",
      "Bash(pnpm i)",
      "Bash(pnpm dev *)",
      "Bash(pnpm dev)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git -C * add *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * push *)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:*)",
      "Bash(pnpm exec biome check --error-on-warnings *)",
      "Bash(pnpm exec tsx scripts/snapshot-grid.ts *)",
      "Bash(npx tsc --noEmit *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d node_modules ] || pnpm i || true",
            "statusMessage": "Installing dependencies..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .port ] && PORT=$(cat .port) && PID=$(ss -tlnp \"sport = :$PORT\" 2>/dev/null | grep -oP 'pid=\\K[0-9]+' | head -1) && [ -n \"$PID\" ] && kill -- -$(ps -o pgid= -p $PID 2>/dev/null | tr -d ' ') 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright-skill@playwright-skill": true,
    "frontend-design@claude-plugins-official": true
  }
}
