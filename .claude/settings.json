{
  "permissions": {
    "allow": [
      "Bash(pnpm tsc --noEmit *)",
      "Bash(pnpm tsc --noEmit)",
      "Bash(pnpm exec tsc --noEmit *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint)",
      "Bash(pnpm test *)",
      "Bash(pnpm test)",
      "Bash(pnpm vitest run *)",
      "Bash(pnpm vitest run)",
      "Bash(pnpm exec vitest run *)",
      "Bash(pnpm i *)",
      "Bash(pnpm i)",
      "Bash(pnpm dev *)",
      "Bash(pnpm dev)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git -C * add *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * push *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git -C * stash)",
      "Bash(git -C * stash *)",
      "Bash(git checkout -b *)",
      "Bash(git -C * checkout -b *)",
      "Bash(gh pr create *)",
      "Bash(gh issue create *)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:*)",
      "Bash(curl -s -o /dev/null http://localhost:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\n\" \"http://localhost:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\n\" http://localhost:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code} %{content_type}\\n\" http://localhost:*)",
      "Bash(curl -v http://localhost:*)",
      "Bash(curl -s --max-time 5 -o /dev/null -w \"%{http_code}\" \"http://localhost:*)",
      "Bash(pnpm exec biome check --error-on-warnings *)",
      "Bash(pnpm biome check *)",
      "Bash(pnpm exec biome check *)",
      "Bash(pnpm format)",
      "Bash(pnpm format *)",
      "Bash(pnpm validate)",
      "Bash(pnpm validate *)",
      "Bash(pnpm snapshot-grid)",
      "Bash(pnpm snapshot-grid *)",
      "Bash(npx tsc --noEmit *)",
      "Bash(pnpm kill-server)",
      "Bash(pnpm kill-server *)",
      "Bash(pnpm playwright test *)",
      "Bash(pnpm playwright test)",
      "Bash(pnpm playwright show-report)",
      "Bash(pnpm playwright test --config temp.playwright.config.ts *)",
      "Bash(pnpm exec playwright test *)",
      "Bash(npx playwright test *)",
      "Bash(pnpm stryker run *)",
      "Bash(pnpm exec stryker run *)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "api.github.com",
        "fonts.googleapis.com",
        "fonts.gstatic.com"
      ]
    },
    "excludedCommands": [
      "pnpm dev",
      "pnpm kill-server"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{ const p=JSON.parse(d)?.tool_input?.file_path; if(p) process.stdout.write(p); })\" | { read -r f; [ -n \"$f\" ] && pnpm exec biome format --write \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d node_modules ] || pnpm i || true",
            "statusMessage": "Installing dependencies..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .port ] && PORT=$(cat .port) && PID=$(ss -tlnp \"sport = :$PORT\" 2>/dev/null | grep -oP 'pid=\\K[0-9]+' | head -1) && [ -n \"$PID\" ] && kill -- -$(ps -o pgid= -p $PID 2>/dev/null | tr -d ' ') 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright-skill@playwright-skill": false,
    "frontend-design@claude-plugins-official": false
  }
}
