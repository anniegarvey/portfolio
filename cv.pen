                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "cv221xwh",
                      "fill": "#F9FAFB",
                      "content": "Sky — Senior Developer",
                      "fontFamily": "Lexend",
                      "fontSize": 18,
                      "fontWeight": "semibold"
                    },
                    {
                      "type": "text",
                      "id": "cv222KYi",
                      "fill": "#9CA3AF",
                      "content": "Sep 2020 – Apr 2021",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv223eVv",
                      "fill": "#D1D5DB",
                      "content": "• Delivered key features for the replatformed CRM front end supporting Sky Glass & Stream.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv224r4T",
                      "fill": "#D1D5DB",
                      "content": "• Identified architectural gaps and proposed pragmatic solutions to improve performance, maintainability, and security.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv225f6Z",
                      "fill": "#D1D5DB",
                      "content": "• Mentored mid-level and junior engineers, supporting their progression to senior roles.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "cv233BbB",
                  "name": "role",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "padding": [
