                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "cv207UUR",
                      "fill": "#F9FAFB",
                      "content": "Sky — Principal Engineer",
                      "fontFamily": "Lexend",
                      "fontSize": 18,
                      "fontWeight": "semibold"
                    },
                    {
                      "type": "text",
                      "id": "cv208isZ",
                      "fill": "#9CA3AF",
                      "content": "Dec 2022 – Present",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv209vM1",
                      "fill": "#D1D5DB",
                      "content": "• Provided technical leadership across multiple teams delivering customer service and CRM platforms.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv210w7W",
                      "fill": "#D1D5DB",
                      "content": "• Led platform-wide initiatives to improve accessibility, security, and developer experience.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv211MDA",
                      "fill": "#D1D5DB",
                      "content": "• Acted as first responder for critical security incidents, rapidly diagnosing and mitigating high-severity threats.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv212KNG",
                      "fill": "#D1D5DB",
                      "content": "• Drove architectural improvements across React and GraphQL services, including the new AI‑integrated SkyGate layer.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv213jHm",
                      "fill": "#D1D5DB",
                      "content": "• Supported engineers across the organisation through mentoring, code reviews, and community-building.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "cv220XDP",
                  "name": "role",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "padding": [
                    16,
                    0,
                    0,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "cv215Auy",
                      "fill": "#F9FAFB",
                      "content": "Sky — Tech Lead",
                      "fontFamily": "Lexend",
                      "fontSize": 18,
                      "fontWeight": "semibold"
                    },
                    {
                      "type": "text",
                      "id": "cv2169RJ",
                      "fill": "#9CA3AF",
                      "content": "Apr 2021 – Jan 2023",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv217QxA",
                      "fill": "#D1D5DB",
                      "content": "• Led feature teams delivering major components of Sky's CRM and digital sales platforms.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv218w8D",
                      "fill": "#D1D5DB",
                      "content": "• Guided technical design, prioritisation, and delivery across multi-team initiatives.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cv219jgo",
                      "fill": "#D1D5DB",
                      "content": "• Provided hands-on support during high-pressure delivery phases, ensuring deadlines were met without compromising quality.",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "cv2262Fu",
                  "name": "role",
